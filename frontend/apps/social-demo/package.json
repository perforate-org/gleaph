{
  "name": "@gleaph/social-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "generate-gateway-bindings": "icp-bindgen --did-file ../../../crates/social-demo-gateway/social_demo_gateway.did --out-dir ./src/generated --force",
    "build:gql-formatter": "node scripts/build-gql-formatter.mjs",
    "generate:avatars": "node scripts/generate-avatar-assets.mjs",
    "check": "$PWD/../../../scripts/check-social-demo-gateway-candid.sh && icp-bindgen --did-file ../../../crates/social-demo-gateway/social_demo_gateway.did --out-dir ./src/generated --force && pnpm run build:gql-formatter && tsc --noEmit",
    "build": "$PWD/../../../scripts/check-social-demo-gateway-candid.sh && icp-bindgen --did-file ../../../crates/social-demo-gateway/social_demo_gateway.did --out-dir ./src/generated --force && pnpm run build:gql-formatter && vite build",
    "build:config": "node scripts/build-config.mjs",
    "dev": "vite",
    "preview": "vite preview"
  },
  "dependencies": {
    "@icp-sdk/core": "^5.4.0",
    "@solid-primitives/i18n": "^2.2.1",
    "@solid-primitives/intersection-observer": "2.1.5",
    "solid-js": "^1.9.14"
  },
  "devDependencies": {
    "@icp-sdk/bindgen": "^0.4.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.0",
    "autoprefixer": "^10.5.2",
    "tailwindcss": "^4.3.2",
    "typescript": "^7.0.0",
    "vite": "^8.0.0",
    "vite-plugin-solid": "^2.11.12",
    "yaml": "^2.9.0"
  }
}
