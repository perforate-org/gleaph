{
  "name": "@gleaph/social-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "generate-gateway-bindings": "icp-bindgen --did-file ../../../crates/social-demo-gateway/social_demo_gateway.did --out-dir ./src/generated --force",
    "check": "$PWD/../../../scripts/check-social-demo-gateway-candid.sh && icp-bindgen --did-file ../../../crates/social-demo-gateway/social_demo_gateway.did --out-dir ./src/generated --force && tsc --noEmit",
    "build": "$PWD/../../../scripts/check-social-demo-gateway-candid.sh && icp-bindgen --did-file ../../../crates/social-demo-gateway/social_demo_gateway.did --out-dir ./src/generated --force && vite build",
    "build:config": "node scripts/build-config.mjs",
    "dev": "vite",
    "preview": "vite preview"
  },
  "dependencies": {
    "@icp-sdk/core": "^5.2.0",
    "solid-js": "^1.9.5"
  },
  "devDependencies": {
    "@icp-sdk/bindgen": "^0.4.0",
    "@types/node": "^22.15.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-solid": "^2.11.6",
    "yaml": "^2.6.1"
  }
}
