{
  "name": "gleaph-workspace",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "install:all": "vp install",
    "check": "vp run -r check",
    "test": "vp run -r test",
    "build": "vp run -r build",
    "pack": "vp run -r pack",
    "sdk:check": "vp run @gleaph/sdk#check",
    "sdk:test": "vp run @gleaph/sdk#test",
    "sdk:build": "vp run @gleaph/sdk#build",
    "sdk:pack": "vp run @gleaph/sdk#pack",
    "dashboard:dev": "pnpm --filter @gleaph/dashboard dev",
    "dashboard:check": "vp run @gleaph/dashboard#check",
    "dashboard:build": "vp run @gleaph/dashboard#build",
    "knowledge-map:dev": "pnpm --filter @gleaph/knowledge-map dev",
    "knowledge-map:check": "pnpm --filter @gleaph/knowledge-map check",
    "knowledge-map:build": "pnpm --filter @gleaph/knowledge-map build",
    "social-demo:dev": "pnpm --filter @gleaph/social-demo dev",
    "social-demo:check": "pnpm --filter @gleaph/social-demo check",
    "social-demo:build": "pnpm --filter @gleaph/social-demo build"
  },
  "devDependencies": {
    "vite-plus": "^0.1.15"
  }
}
