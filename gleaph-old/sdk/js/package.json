{
  "name": "@gleaph/sdk",
  "version": "0.1.0",
  "description": "JavaScript/TypeScript SDK for Gleaph graph database on the Internet Computer",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@icp-sdk/core": ">=5.0.0",
    "@icp-sdk/auth": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@icp-sdk/auth": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@icp-sdk/auth": "^5.0.0",
    "@icp-sdk/core": "^5.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "license": "MIT"
}
